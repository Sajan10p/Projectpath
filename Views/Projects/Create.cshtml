@model Projectpath.Models.CreateProjectViewModel
@{
    ViewData["Title"] = "Submit Project";
}

<div class="card p-4 shadow-sm col-lg-8 mx-auto">
    <h3 class="mb-4">Submit New Project</h3>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="Requirements" class="form-label"></label>
            <textarea asp-for="Requirements" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="Program" class="form-label"></label>
            <input asp-for="Program" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ProjectType" class="form-label"></label>
            <input asp-for="ProjectType" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ContactPersonName" class="form-label"></label>
            <input asp-for="ContactPersonName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ContactPhone" class="form-label"></label>
            <input asp-for="ContactPhone" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ContactPersonEmail" class="form-label"></label>
            <input asp-for="ContactPersonEmail" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ExpectedDurationWeeks" class="form-label"></label>
            <input asp-for="ExpectedDurationWeeks" class="form-control" />
        </div>

        <button class="btn btn-dark">Submit Project</button>
    </form>
</div>