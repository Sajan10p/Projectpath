@model IEnumerable<Projectpath.Models.Project>

@{
    ViewData["Title"] = "Browse Projects";
}

<div class="page-header-proto">
    <div>
        <h2>Available Projects</h2>
        <p>Browse and select from available industry projects.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No approved projects are available yet.
    </div>
}
else
{
    <div class="row">
        @foreach (var project in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <h4>@project.Title</h4>
                        <span class="badge bg-success">Available</span>
                    </div>

                    <p class="text-muted">
                        @(project.Company?.FullName ?? "Company")
                    </p>

                    <p>
                        @(project.Description != null && project.Description.Length > 140
                                        ? project.Description.Substring(0, 140) + "..."
                                        : project.Description)
            </p>

                    <div class="mt-auto">
                        <a asp-controller="Projects"
                           asp-action="Details"
                           asp-route-id="@project.Id"
                           class="btn btn-dark-custom w-100">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}