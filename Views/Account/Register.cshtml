@model Projectpath.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - ProjectPath</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-card" style="max-width: 620px;">
        <div class="auth-brand">
            <div class="brand-logo">PP</div>
            <div>
                <div class="brand-title text-dark">ProjectPath</div>
                <div class="brand-subtitle text-secondary">Create your account to join the platform</div>
            </div>
        </div>

        <h2 class="auth-title">Create Account</h2>
        <p class="auth-subtitle">Register as a student, tutor, or company user.</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold"></label>
                <input asp-for="FullName" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label fw-semibold"></label>
                <select asp-for="Role" class="form-select" id="roleSelect">
                    <option value="">-- Select Role --</option>
                    <option value="Student">Student</option>
                    <option value="Tutor">Tutor</option>
                    <option value="Company">Company</option>
                </select>
            </div>

            <div class="mb-3" id="studentIdBox" style="display:none;">
                <label asp-for="StudentNumber" class="form-label fw-semibold"></label>
                <input asp-for="StudentNumber" class="form-control" />
            </div>

            <div class="mb-3" id="tutorIdBox" style="display:none;">
                <label asp-for="TutorNumber" class="form-label fw-semibold"></label>
                <input asp-for="TutorNumber" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control" />
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
            </div>

            <button type="submit" class="btn btn-accent w-100 mb-3">Create Account</button>

            <div class="text-center">
                <span class="text-muted">Already have an account?</span>
                <a asp-controller="Account" asp-action="Login" class="fw-semibold ms-1" style="color: var(--pp-accent-dark);">Login</a>
            </div>
        </form>
    </div>

    <script>
        function toggleRoleFields() {
            const role = document.getElementById("roleSelect").value;
            document.getElementById("studentIdBox").style.display = role === "Student" ? "block" : "none";
            document.getElementById("tutorIdBox").style.display = role === "Tutor" ? "block" : "none";
        }

        document.getElementById("roleSelect").addEventListener("change", toggleRoleFields);
        toggleRoleFields();
    </script>

</body>
</html>