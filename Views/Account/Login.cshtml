@model Projectpath.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - ProjectPath</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">

    <div class="auth-card">
        <div class="auth-brand">
            <div class="brand-logo">PP</div>
            <div>
                <div class="brand-title text-dark">ProjectPath</div>
                <div class="brand-subtitle text-secondary">Secure access to your project dashboard</div>
            </div>
        </div>

        <h2 class="auth-title">Welcome Back</h2>
        <p class="auth-subtitle">Login to continue managing projects, teams, and progress updates.</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control" />
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-dark-custom w-100 mb-3">Login</button>

            <div class="text-center">
                <span class="text-muted">Don’t have an account?</span>
                <a asp-controller="Account" asp-action="Register" class="fw-semibold ms-1" style="color: var(--pp-accent-dark);">Register</a>
            </div>
        </form>
    </div>

</body>
</html>