@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row">
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Pending Registrations</h5>
                <h3>@ViewBag.PendingRegistrations</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Total Projects</h5>
                <h3>@ViewBag.TotalProjects</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Pending Projects</h5>
                <h3>@ViewBag.PendingProjects</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>Unviewed Submissions</h5>
                <h3>@ViewBag.UnviewedSubmissions</h3>
            </div>
        </div>
    </div>
</div>