@model IEnumerable<Projectpath.Models.Submission>

@{
    ViewData["Title"] = "Student Submissions";
}

<h2>Student Submissions</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No submissions yet.</div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Project</th>
                <th>File</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Student?.FullName</td>
                <td>@s.Assignment?.Project?.Title</td>
                <td>@s.FileName</td>
                <td>@s.Status</td>
                <td>@s.SubmittedAt</td>
                <td>
                    <a asp-action="DownloadSubmission" asp-route-id="@s.Id" class="btn btn-dark btn-sm">Download</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}