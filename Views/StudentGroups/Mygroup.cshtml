@model Projectpath.Models.GroupMember
@using Projectpath.Models

@{
    ViewData["Title"] = "My Group";
    var availableStudents = ViewBag.AvailableStudents as List<AvailableStudentViewModel> ?? new();
    var joinRequests = ViewBag.JoinRequests as List<GroupJoinRequest> ?? new();
    var leaveRequests = ViewBag.LeaveRequests as List<GroupLeaveRequest> ?? new();
    bool hasPendingLeaveRequest = ViewBag.HasPendingLeaveRequest != null && (bool)ViewBag.HasPendingLeaveRequest;
}

@if (Model == null)
{
    <div class="page-header-proto">
        <div>
            <h2>My Group</h2>
            <p>You are not in any group yet.</p>
        </div>
    </div>

    <div class="card p-4">
        <p class="mb-3">Join an existing group or create a new one from approved projects.</p>
        <div class="d-flex gap-2">
            <a asp-controller="StudentGroups" asp-action="AvailableGroups" class="btn btn-outline-dark">View Available Groups</a>
            <a asp-controller="Projects" asp-action="Approved" class="btn btn-dark">Browse Projects</a>
        </div>
    </div>
}
else
{
    <div class="page-header-proto">
        <div>
            <h2>My Group</h2>
            <p>Manage your group members, invitations, and requests.</p>
        </div>
    </div>

    <div class="card p-4 mb-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h3 class="mb-1">@Model.StudentGroup?.GroupName</h3>
                <div class="text-muted">@Model.StudentGroup?.Project?.Title</div>
                <div class="small text-muted mt-1">Created on @Model.StudentGroup?.CreatedAt.ToString("dd/MM/yyyy")</div>
            </div>
            <div>
                <small class="text-muted d-block">Group Status</small>
                <span class="badge bg-primary">@Model.StudentGroup?.Status</span>
            </div>
        </div>
    </div>

    <div class="card p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Group Members</h4>
            <span class="badge bg-secondary">@((Model.StudentGroup?.Members.Count ?? 0)) / 5 Members</span>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Student ID</th>
                    <th>Leader</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model.StudentGroup?.Members ?? new List<GroupMember>())
                {
                    <tr>
                        <td>@member.Student?.FullName</td>
                        <td>@member.Student?.Email</td>
                        <td>@member.Student?.StudentNumber</td>
                        <td>
                            @if (member.IsLeader)
                            {
                                <span class="badge bg-success">Leader</span>
                            }
                            else
                            {
                                <span class="text-muted">Member</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card p-4 h-100">
                <h4 class="mb-3">Leave Group</h4>

                @if (Model.IsLeader)
                {
                    <p class="text-muted">
                        You are the group leader. You must transfer leadership before leaving the group.
                    </p>
                    <button class="btn btn-secondary" disabled>Leader Cannot Leave</button>
                }
                else if (hasPendingLeaveRequest)
                {
                    <p class="text-muted">
                        Your leave request is pending leader approval.
                    </p>
                    <button class="btn btn-warning" disabled>Leave Request Pending</button>
                }
                else
                {
                    <p class="text-muted">
                        Leaving the group requires approval from the leader.
                    </p>
                    <form asp-action="RequestLeaveGroup" method="post">
                        <button type="submit" class="btn btn-danger">Request to Leave Group</button>
                    </form>
                }
            </div>
        </div>

        @if (Model.IsLeader)
        {
            <div class="col-lg-6">
                <div class="card p-4 h-100">
                    <h4 class="mb-3">Transfer Leadership</h4>
                    <form asp-action="TransferLeadership" method="post">
                        <input type="hidden" name="studentGroupId" value="@Model.StudentGroupId" />
                        <div class="mb-3">
                            <select name="newLeaderStudentId" class="form-select" required>
                                <option value="">-- Select Member --</option>
                                @foreach (var member in Model.StudentGroup?.Members.Where(x => !x.IsLeader) ?? new List<GroupMember>())
                                {
                                    <option value="@member.StudentId">@member.Student?.FullName (@member.Student?.StudentNumber)</option>
                                }
                            </select>
                        </div>
                        <button class="btn btn-warning">Transfer Leadership</button>
                    </form>
                </div>
            </div>
        }
    </div>

    @if (Model.IsLeader)
    {
        <div class="card p-4 mt-4">
            <h4 class="mb-3">Join Requests</h4>

            @if (joinRequests.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Student ID</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in joinRequests)
                        {
                            <tr>
                                <td>@request.Student?.FullName</td>
                                <td>@request.Student?.Email</td>
                                <td>@request.Student?.StudentNumber</td>
                                <td class="d-flex gap-2">
                                    <form asp-action="ApproveJoinRequest" method="post">
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                    <form asp-action="RejectJoinRequest" method="post">
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-danger">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No pending join requests.</p>
            }
        </div>

        <div class="card p-4 mt-4">
            <h4 class="mb-3">Leave Requests</h4>

            @if (leaveRequests.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Student ID</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in leaveRequests)
                        {
                            <tr>
                                <td>@request.Student?.FullName</td>
                                <td>@request.Student?.Email</td>
                                <td>@request.Student?.StudentNumber</td>
                                <td class="d-flex gap-2">
                                    <form asp-action="ApproveLeaveRequest" method="post">
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-success">Approve</button>
                                    </form>

                                    <form asp-action="RejectLeaveRequest" method="post">
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-danger">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No pending leave requests.</p>
            }
        </div>

        <div class="card p-4 mt-4">
            <h4 class="mb-3">Invite Student by Student ID</h4>
            <form asp-action="Invite" method="post" class="row g-3">
                <input type="hidden" name="StudentGroupId" value="@Model.StudentGroupId" />
                <div class="col-md-9">
                    <input name="StudentNumber" class="form-control" placeholder="Enter student ID" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-dark w-100">Send Invite</button>
                </div>
            </form>
        </div>

        <div class="card p-4 mt-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <h4 class="mb-0">Available Students</h4>
                <input type="text" id="studentSearch" class="form-control" style="max-width: 280px;" placeholder="Search by name or ID" />
            </div>

            @if (availableStudents.Any())
            {
                <table class="table" id="studentsTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Student ID</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in availableStudents)
                        {
                            <tr>
                                <td>@student.FullName</td>
                                <td>@student.Email</td>
                                <td>@student.StudentNumber</td>
                                <td>
                                    <form asp-action="InviteByStudentNumber" method="post">
                                        <input type="hidden" name="studentGroupId" value="@Model.StudentGroupId" />
                                        <input type="hidden" name="studentNumber" value="@student.StudentNumber" />
                                        <button class="btn btn-sm btn-outline-dark">Invite</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No available students to invite.</p>
            }
        </div>
    }
}

@section Scripts {
    <script>
        document.getElementById("studentSearch")?.addEventListener("keyup", function () {
            const value = this.value.toLowerCase();
            const rows = document.querySelectorAll("#studentsTable tbody tr");
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
            });
        });
    </script>
}