@model IEnumerable<Projectpath.Models.ApplicationUser>

@{
    ViewData["Title"] = "Chat";

    var availableUsers = ViewBag.AvailableUsers as List<Projectpath.Models.ApplicationUser>
                         ?? new List<Projectpath.Models.ApplicationUser>();

    string currentUserRole = ViewBag.CurrentUserRole as string ?? "";

    var adminUsers = availableUsers
        .Where(u => u.UserRole == "Admin")
        .ToList();

    var studentUsers = availableUsers
        .Where(u => u.UserRole == "Student")
        .ToList();

    var tutorUsers = availableUsers
        .Where(u => u.UserRole == "Tutor")
        .ToList();

    var companyUsers = availableUsers
        .Where(u => u.UserRole == "Company")
        .ToList();
}

<div class="page-header-proto">
    <div>
        <h2>Chat</h2>

        @if (currentUserRole == "Student")
        {
            <p>Chat with admin, group members, assigned tutor, and your project company.</p>
        }
        else if (currentUserRole == "Tutor")
        {
            <p>Chat with admin and your assigned students.</p>
        }
        else if (currentUserRole == "Company")
        {
            <p>Chat with admin and group leaders of your projects.</p>
        }
        else if (currentUserRole == "Admin")
        {
            <p>Chat with students, tutors, and companies.</p>
        }
        else
        {
            <p>Start conversations with users available to your role.</p>
        }
    </div>
</div>

@if (currentUserRole == "Admin")
{
    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card p-4 h-100 shadow-sm">
                <h4>Students</h4>
                <p class="text-muted">Chat with approved student users.</p>

                @if (!studentUsers.Any())
                {
                    <div class="alert alert-info mb-0">No students available.</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var user in studentUsers)
                        {
                            <a asp-controller="Chat"
                               asp-action="Conversation"
                               asp-route-userId="@user.Id"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@user.FullName</strong>
                                    <div class="text-muted small">@user.Email</div>
                                    <span class="badge bg-secondary">@user.UserRole</span>
                                </div>

                                <span class="btn btn-sm btn-dark">Chat</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card p-4 h-100 shadow-sm">
                <h4>Tutors</h4>
                <p class="text-muted">Chat with approved tutor users.</p>

                @if (!tutorUsers.Any())
