@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">

    <!-- HERO SECTION -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">ProjectPath</h1>
        <p class="lead">Student Project Management System</p>
        <p class="text-muted">
            Manage projects, assign students, track progress and collaborate efficiently.
        </p>

    </div>

    <!-- FEATURES -->
    <div class="row text-center">

        <div class="col-md-3">
            <div class="card shadow p-3 mb-4">
                <h4>📂 Projects</h4>
                <p>Companies submit projects and admins approve them.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow p-3 mb-4">
                <h4>👨‍🎓 Students</h4>
                <p>Students can browse and select available projects.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow p-3 mb-4">
                <h4>👨‍🏫 Tutors</h4>
                <p>Tutors track progress and guide students.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow p-3 mb-4">
                <h4>📊 Dashboard</h4>
                <p>Monitor project status and completion.</p>
            </div>
        </div>

    </div>

    <!-- INFO SECTION -->
    <div class="mt-5 text-center">
        <h3>Why ProjectPath?</h3>
        <p class="text-muted">
            Replace manual spreadsheets with a centralized system for managing academic projects efficiently.
        </p>
    </div>

</div>